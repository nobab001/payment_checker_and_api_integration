# ============================================================
# Payment Checker OTP System — Environment Configuration
# ============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit .env to version control!
# ============================================================


# ============================================================
# DATABASE (MySQL / MariaDB)
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=payment_checker


# ============================================================
# JWT AUTHENTICATION
# ============================================================
# Generate a strong random secret:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-min-32-chars
JWT_EXPIRES_IN=7d


# ============================================================
# OTP SETTINGS
# ============================================================
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_RESEND_COOLDOWN_SEC=60


# ============================================================
# GMAIL / NODEMAILER (for email OTP)
# ============================================================
# Use a Gmail App Password — NOT your regular Google password!
# How to get one: https://myaccount.google.com/apppasswords
#   1. Go to Google Account → Security → 2-Step Verification
#   2. Scroll to "App passwords" → create one for "Mail"
#   3. Copy the 16-character password (no spaces) into GMAIL_PASS
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=xxxxxxxxxxxxxxxxxxxx
GMAIL_FROM=your-email@gmail.com
GMAIL_OTP_SUBJECT=Payment Checker - Your Verification Code


# ============================================================
# SMS GATEWAY
# ============================================================
# Leave SMS_API_URL empty to disable SMS (email OTP will still work).
#
# ── BulkSMSBD (bulksmsbd.net) ──────────────────────────────
# SMS_API_URL=https://bulksmsbd.net/api/smsapi
# SMS_API_KEY=your_api_key_here
# SMS_API_SECRET=
# SMS_SENDER_ID=PayChek
#
# ── SSL Wireless ──────────────────────────────────────────
# SMS_API_URL=http://api2.mobireach.com.bd/SendTextMessage
# SMS_API_KEY=your_username
# SMS_API_SECRET=your_password
# SMS_SENDER_ID=PayChek
#
# ── Twilio ────────────────────────────────────────────────
# SMS_API_URL=https://api.twilio.com/2010-04-01/Accounts/AC.../Messages.json
# SMS_API_KEY=AC...             (Account SID)
# SMS_API_SECRET=your_auth_token
# SMS_SENDER_ID=+1234567890
#
SMS_API_URL=
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=


# ============================================================
# APP FEATURE FLAGS
# ============================================================
# Set APP_ENABLED=false to show maintenance banner in the app
APP_ENABLED=true


# ============================================================
# SOCIAL LINKS  (shown on the login screen)
# ============================================================
SOCIAL_WHATSAPP=
SOCIAL_FACEBOOK=
SOCIAL_TELEGRAM=
SOCIAL_YOUTUBE=


# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=3000
NODE_ENV=production

# CORS — comma-separated allowed origins, or * for all
CORS_ORIGIN=https://paychek.online,https://www.paychek.online
