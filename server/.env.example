PORT=3000
DB_HOST=127.0.0.1
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_database_name
JWT_SECRET=use-a-long-random-string

# Gmail OTP (@gmail.com login): Google account + 16-char App Password
GMAIL_USER=your.sender@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Optional: override From header / subject
# GMAIL_FROM=your.sender@gmail.com
# GMAIL_OTP_SUBJECT=আপনার OTP কোড - Payment Checker

# Optional:
# OTP_EXPIRY_MIN=10
# OTP_RESEND_COOLDOWN_SEC=60
# JWT_EXPIRES=30d