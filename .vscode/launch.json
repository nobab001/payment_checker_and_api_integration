      "cwd": "${workspaceFolder}",
      "program": "lib/main.dart",
      "toolArgs": ["-d", "android", "--flavor", "user"]
    },
    {
      "name": "Debug User App",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}",
      "program": "lib/main.dart",
      "toolArgs": ["-d", "android", "--flavor", "user"]
    },
    {
      "name": "Debug Admin App",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}",
      "program": "lib/main_admin.dart",
      "toolArgs": ["-d", "android", "--flavor", "admin"]
    },
    {
      "name": "User App — Android (pick device)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}",
      "program": "lib/main.dart",
      "toolArgs": ["--flavor", "user"]
    },
    {
      "name": "User App — Chrome",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}",
      "program": "lib/main.dart",
      "toolArgs": ["-d", "chrome"]
