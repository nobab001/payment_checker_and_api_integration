    {
      "name": "Admin App — Edge",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/admin",
      "program": "lib/main.dart",
      "toolArgs": ["-d", "edge"]
    }
  ],
  "compounds": [
    {
      "name": "User phone + Admin Chrome (একসাথে)",
      "configurations": ["User → phone (Android, flavor user)", "Admin → Chrome"],
      "stopAll": true,
      "presentation": {
        "group": "payment_checker",
