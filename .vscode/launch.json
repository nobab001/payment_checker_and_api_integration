      "stopAll": true,
      "presentation": {
        "group": "payment_checker",
        "order": 2
      }
    },
    {
      "name": "একসাথে: User + Admin (দুইটি Android অ্যাপ)",
      "configurations": ["Debug User App", "Debug Admin App"],
      "stopAll": true,
